#!/usr/bin/env bash
# Pre-commit hook: format staged Kotlin files with ktfmt (Google style).
# Installed by `./gradlew installGitHooks` (sets core.hooksPath = .githooks).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Collect staged Kotlin files (Added/Copied/Modified/Renamed), NUL-terminated.
mapfile -d '' -t staged < <(
  git diff --cached --name-only --diff-filter=ACMR -z -- '*.kt' '*.kts'
)

if [[ ${#staged[@]} -eq 0 ]]; then
  exit 0
fi

# Run ktfmtCheck against the whole project. Fast on incremental builds; if
# something is unformatted, the offending file paths are printed and we abort
# the commit so the developer can run `./gradlew ktfmtFormat` and re-stage.
if ! ./gradlew --quiet ktfmtCheck; then
  echo
  echo "ktfmt found formatting issues. Fix with:"
  echo "    ./gradlew ktfmtFormat"
  echo "then 'git add' the changes and re-commit."
  exit 1
fi
